{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ghost-ark.local/schemas/runtime-attestation-policy.json",
  "title": "Ghost Ark runtime attestation policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "allowedTypes"],
  "properties": {
    "schemaVersion": { "const": "ghost.runtime_attestation_policy.v1" },
    "allowedTypes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["local-dev-attestation", "aws-nitro-enclave"]
      }
    },
    "requiredRuntimeIds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "allowedImageDigests": {
      "type": "array",
      "items": { "$ref": "#/$defs/sha256Digest" }
    },
    "allowedCodeDigests": {
      "type": "array",
      "items": { "$ref": "#/$defs/sha256Digest" }
    },
    "allowedPolicyCompilerDigests": {
      "type": "array",
      "items": { "$ref": "#/$defs/sha256Digest" }
    },
    "requiredMeasurements": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pcr0": { "$ref": "#/$defs/measurementPins" },
        "pcr1": { "$ref": "#/$defs/measurementPins" },
        "pcr2": { "$ref": "#/$defs/measurementPins" },
        "pcr3": { "$ref": "#/$defs/measurementPins" },
        "pcr4": { "$ref": "#/$defs/measurementPins" },
        "pcr8": { "$ref": "#/$defs/measurementPins" }
      }
    },
    "maxClockSkewMs": {
      "type": "integer",
      "minimum": 0
    },
    "requireBindingToReceipt": { "type": "boolean" },
    "requireBindingToCheckpoint": { "type": "boolean" },
    "requireBindingToPayload": { "type": "boolean" }
  },
  "$defs": {
    "sha256Digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "measurementPins": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
