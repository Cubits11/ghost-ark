{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ghost-ark.dev/schemas/research/frontier-manifest.schema.json",
  "title": "Ghost-Ark Research Frontier Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_id",
    "git_commit",
    "claims",
    "non_claims",
    "evidence"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "ghostark.research.frontier_manifest.v1"
    },
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "git_commit": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "claims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "non_claims": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_item"
      }
    }
  },
  "$defs": {
    "claim": {
      "type": "object",
      "required": ["id", "phase", "statement", "status"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "type": "string",
          "enum": ["phase_0", "phase_a", "phase_b", "phase_c", "phase_d"]
        },
        "statement": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["not_started", "experimental", "implemented", "verified", "retracted"]
        }
      },
      "additionalProperties": false
    },
    "evidence_item": {
      "type": "object",
      "required": ["id", "type", "path", "sha256"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "test_report",
            "formal_model",
            "attestation_manifest",
            "zk_receipt",
            "witness_checkpoint",
            "source_file",
            "security_review"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
