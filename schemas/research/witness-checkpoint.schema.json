{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ghost-ark.dev/schemas/research/witness-checkpoint.schema.json",
  "title": "Ghost-Ark Witness Checkpoint",
  "type": "object",
  "required": [
    "schema_version",
    "log_id",
    "tree_size",
    "root_hash",
    "integrated_time",
    "witness_signatures"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "ghostark.research.witness_checkpoint.v1"
    },
    "log_id": {
      "type": "string",
      "minLength": 1
    },
    "tree_size": {
      "type": "integer",
      "minimum": 0
    },
    "root_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "integrated_time": {
      "type": "string",
      "format": "date-time"
    },
    "witness_signatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["witness_id", "signature_algorithm", "signature"],
        "properties": {
          "witness_id": { "type": "string", "minLength": 1 },
          "signature_algorithm": {
            "type": "string",
            "enum": ["ed25519", "ecdsa-p256-sha256", "kms-ecdsa-sha256"]
          },
          "signature": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
