{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ghost-ark.dev/schemas/research/human-review-decision.schema.json",
  "title": "Ghost-Ark Human Review Decision",
  "type": "object",
  "required": [
    "schema_version",
    "decision_id",
    "queue_item_id",
    "decided_at",
    "reviewer",
    "disposition",
    "rationale_codes",
    "rationale_digest",
    "receipt_references",
    "evidence_references",
    "escalation",
    "privacy",
    "audit",
    "non_claims"
  ],
  "properties": {
    "schema_version": {
      "const": "ghostark.research.human_review_decision.v1"
    },
    "decision_id": {
      "type": "string",
      "pattern": "^hrd_[A-Za-z0-9_-]+$"
    },
    "queue_item_id": {
      "type": "string",
      "pattern": "^hrq_[A-Za-z0-9_-]+$"
    },
    "decided_at": { "type": "string", "format": "date-time" },
    "reviewer": {
      "type": "object",
      "required": ["reviewer_role", "reviewer_id_hash"],
      "properties": {
        "reviewer_role": { "type": "string", "minLength": 1 },
        "reviewer_id_hash": { "$ref": "#/$defs/hmac_sha256_digest" }
      },
      "additionalProperties": false
    },
    "disposition": {
      "enum": [
        "confirmed_violation",
        "false_positive",
        "needs_more_evidence",
        "escalated",
        "no_action"
      ]
    },
    "rationale_codes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "rationale_digest": { "$ref": "#/$defs/sha256_digest" },
    "receipt_references": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/receipt_reference" }
    },
    "evidence_references": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence_reference" }
    },
    "escalation": {
      "oneOf": [
        {
          "type": "object",
          "required": ["required", "incident_id", "reason_code"],
          "properties": {
            "required": { "const": true },
            "incident_id": {
              "type": "string",
              "pattern": "^inc_[A-Za-z0-9_-]+$"
            },
            "reason_code": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["required", "incident_id", "reason_code"],
          "properties": {
            "required": { "const": false },
            "incident_id": { "type": "null" },
            "reason_code": { "type": "null" }
          },
          "additionalProperties": false
        }
      ]
    },
    "privacy": { "$ref": "#/$defs/privacy" },
    "audit": { "$ref": "#/$defs/audit_link" },
    "non_claims": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "disposition": { "const": "escalated" } } },
      "then": {
        "properties": {
          "escalation": { "properties": { "required": { "const": true } } }
        }
      },
      "else": {
        "properties": {
          "escalation": { "properties": { "required": { "const": false } } }
        }
      }
    }
  ],
  "$defs": {
    "sha256_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "hmac_sha256_digest": {
      "type": "string",
      "pattern": "^hmac-sha256:[a-f0-9]{64}$"
    },
    "receipt_reference": {
      "type": "object",
      "required": ["receipt_id", "receipt_digest"],
      "properties": {
        "receipt_id": { "type": "string", "minLength": 1 },
        "receipt_digest": { "$ref": "#/$defs/sha256_digest" }
      },
      "additionalProperties": false
    },
    "evidence_reference": {
      "type": "object",
      "required": ["artifact_type", "artifact_id", "artifact_digest"],
      "properties": {
        "artifact_type": {
          "enum": [
            "guardrail_observation",
            "receipt",
            "policy",
            "verifier_report",
            "review_queue_item",
            "review_decision",
            "review_attachment",
            "incident_timeline"
          ]
        },
        "artifact_id": { "type": "string", "minLength": 1 },
        "artifact_digest": { "$ref": "#/$defs/sha256_digest" }
      },
      "additionalProperties": false
    },
    "privacy": {
      "type": "object",
      "required": [
        "raw_content_included",
        "notes_storage",
        "redaction_policy_digest"
      ],
      "properties": {
        "raw_content_included": { "const": false },
        "notes_storage": { "const": "digest_only" },
        "redaction_policy_digest": { "$ref": "#/$defs/sha256_digest" }
      },
      "additionalProperties": false
    },
    "audit_link": {
      "type": "object",
      "required": ["event_id", "event_digest", "previous_event_digest"],
      "properties": {
        "event_id": { "type": "string", "pattern": "^audit_[A-Za-z0-9_-]+$" },
        "event_digest": { "$ref": "#/$defs/sha256_digest" },
        "previous_event_digest": {
          "oneOf": [
            { "$ref": "#/$defs/sha256_digest" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
