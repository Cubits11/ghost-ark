{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ghost-ark.dev/schemas/research/cc-correlation-report.schema.json",
  "title": "Ghost-Ark CC Correlation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "cohort_id",
    "sample_size",
    "variable_summaries",
    "pairwise_summaries",
    "dependence_model",
    "warnings",
    "non_claims"
  ],
  "$defs": {
    "interval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "confidence_level", "lower", "upper"],
      "properties": {
        "method": { "const": "wilson-score" },
        "confidence_level": { "const": 0.95 },
        "lower": { "type": "number", "minimum": 0, "maximum": 1 },
        "upper": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  },
  "properties": {
    "schema_version": { "const": "ghost.cc_correlation_report.v1" },
    "generated_at": { "type": "string", "format": "date-time" },
    "cohort_id": { "type": "string", "minLength": 1 },
    "sample_size": { "type": "integer", "minimum": 1 },
    "variable_summaries": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["variable_id", "failure_count", "failure_rate", "failure_rate_interval"],
        "properties": {
          "variable_id": { "type": "string", "minLength": 1 },
          "failure_count": { "type": "integer", "minimum": 0 },
          "failure_rate": { "type": "number", "minimum": 0, "maximum": 1 },
          "failure_rate_interval": { "$ref": "#/$defs/interval" }
        }
      }
    },
    "pairwise_summaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "left_variable_id",
          "right_variable_id",
          "co_failure_table",
          "observed_joint_failure_rate",
          "joint_failure_interval",
          "frechet_bounds",
          "phi_correlation"
        ],
        "properties": {
          "left_variable_id": { "type": "string", "minLength": 1 },
          "right_variable_id": { "type": "string", "minLength": 1 },
          "co_failure_table": {
            "type": "object",
            "additionalProperties": false,
            "required": ["n00", "n01", "n10", "n11"],
            "properties": {
              "n00": { "type": "integer", "minimum": 0 },
              "n01": { "type": "integer", "minimum": 0 },
              "n10": { "type": "integer", "minimum": 0 },
              "n11": { "type": "integer", "minimum": 0 }
            }
          },
          "observed_joint_failure_rate": { "type": "number", "minimum": 0, "maximum": 1 },
          "joint_failure_interval": { "$ref": "#/$defs/interval" },
          "frechet_bounds": {
            "type": "object",
            "additionalProperties": false,
            "required": ["lower", "upper", "interpretation"],
            "properties": {
              "lower": { "type": "number", "minimum": 0, "maximum": 1 },
              "upper": { "type": "number", "minimum": 0, "maximum": 1 },
              "interpretation": { "type": "string", "minLength": 1 }
            }
          },
          "phi_correlation": {
            "type": ["number", "null"],
            "minimum": -1,
            "maximum": 1
          }
        }
      }
    },
    "dependence_model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "missingness_policy", "stationarity_declaration"],
      "properties": {
        "kind": { "const": "empirical-pairwise" },
        "missingness_policy": { "const": "complete-grid-required" },
        "stationarity_declaration": { "type": "string", "minLength": 1 }
      }
    },
    "warnings": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "non_claims": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
