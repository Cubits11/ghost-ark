{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ghost-ark.dev/schemas/checkpoint-index.schema.json",
  "title": "Ghost-Ark Checkpoint Index Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tenantSlug",
    "epochId",
    "leafCount",
    "merkleRoot",
    "signature",
    "signerKeyId",
    "publishedAt"
  ],
  "properties": {
    "tenantSlug": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,47}$" },
    "epochId": { "type": "string", "minLength": 1 },
    "leafCount": { "type": "integer", "minimum": 0 },
    "merkleRoot": { "type": "string", "pattern": "^(sha256:)?[a-f0-9]{64}$" },
    "leavesHash": { "type": "string" },
    "signature": { "type": "string", "minLength": 1 },
    "signerKeyId": { "type": "string", "minLength": 1 },
    "publishedAt": { "type": "string", "format": "date-time" },
    "gcsCheckpointUri": { "type": "string" }
  }
}
