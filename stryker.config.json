{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "vitest": { "configFile": "vitest.config.ts" },
  "mutate": [
    "packages/research-frontier/src/occ/ghostReplica.ts",
    "packages/research-frontier/src/unification/lpOracle.ts",
    "tools/research/check-forbidden-claims.mjs"
  ],
  "incremental": true,
  "reporters": ["html", "clear-text"],
  "htmlReporter": { "fileName": "artifacts/mutation/report.html" },
  "thresholds": { "high": 95, "low": 90, "break": null },
  "concurrency": 2,
  "timeoutMS": 10000
}
