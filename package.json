{
  "name": "ghost-ark-v50",
  "version": "50.0.0",
  "private": true,
  "license": "MIT",
  "description": "AWS-native evidence lakehouse and cryptographic receipt-control platform.",
  "type": "commonjs",
  "bin": {
    "ghost-verify": "tools/ghost-verify.mjs"
  },
  "workspaces": [
    "apps/api",
    "apps/console",
    "packages/*",
    "services/signing/kms",
    "services/ledger/dynamodb",
    "services/search/opensearch/ingestion",
    "services/ingest/lambda/*",
    "services/transform/lambda/*",
    "infra/cdk",
    "tools/scripts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage cdk.out",
    "docs:check": "node -e \"const fs=require('fs'); const required=['docs/architecture/system-overview.md','docs/architecture/transparency-witness-model.md','docs/compliance/non-claims.md','docs/compliance/control-mapping.json','docs/governance/claim-evidence-matrix.md','docs/governance/risk-register.md','docs/governance/external-reviewer-guide.md','docs/operations/runbooks/live-aws-evidence-preflight.md','docs/operations/runbooks/live-aws-evidence-window.md','docs/operations/runbooks/live-aws-evidence-cleanup.md','docs/operations/runbooks/object-lock-transparency-window.md','docs/research/GUARDRAIL_OBSERVATION_MODEL.md','docs/research/CC_CORRELATION_ANALYSIS.md','docs/research/HUMAN_REVIEW_INCIDENT_WORKFLOW.md','schemas/live-aws-evidence-bundle.schema.json','examples/evidence/live-aws-evidence-bundle.sample.json','README.md']; for (const f of required) { if (!fs.existsSync(f)) throw new Error('Missing '+f); }\"",
    "test:research": "vitest run tests/unit/research-frontier",
    "validate:claims": "node tools/research/check-forbidden-claims.mjs",
    "validate:fast": "npm run test:research && npm run validate:claims",
    "claims:check": "npm run validate:claims",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "validate": "npm run lint && npm test && npm run docs:check && npm run claims:check",
    "ghost-verify": "node tools/ghost-verify.mjs",
    "receipt:verify": "ts-node tools/scripts/receiptVerify.ts",
    "receipt:verify:sample": "npm run ghost-verify -- --receipt examples/sample-receipts/valid-receipt.json --key examples/sample-receipts/public-key.pem --tenant acme-lab",
    "receipt:verify:independent": "node verifiers/node/ghost_receipt_verify.mjs --receipt examples/reproducibility/receipts/hmac-baseline.receipt.json --hmac-secret ghost-ark-repro-signing-dev-only-test-vector-v1 --expected-key-id local-dev-hmac",
    "receipt:verify:repro": "ts-node tools/repro/verify-repro-manifest.ts --manifest examples/reproducibility/manifest.json",
    "receipt:verify:corpus": "npx vitest run tests/security/receipt-negative-corpus.test.ts",
    "receipt:verify:agreement": "npx vitest run tests/differential/nodeIndependentVerifier.test.ts",
    "receipt:verify:replay": "node verifiers/node/replay_receipt_manifests.mjs",
    "receipt:checkpoint": "ts-node tools/scripts/checkpointReceipts.ts",
    "receipt-proof:local": "ts-node tools/scripts/createLocalReceiptProof.ts",
    "policy:counterexamples": "ts-node tools/scripts/verifyTenantPolicyCounterexamples.ts",
    "seed:governed-policy": "ts-node tools/scripts/seedGovernedPolicy.ts",
    "smoke:governed-invoke": "ts-node tools/scripts/smokeGovernedInvoke.ts",
    "supervised:aws-runtime-validation": "ts-node tools/scripts/supervisedAwsRuntimeValidation.ts",
    "research:witness-bundle": "ts-node tools/scripts/createResearchWitnessBundle.ts",
    "validate:evidence-bundle": "ts-node tools/evidence/validate-live-aws-evidence-bundle.ts",
    "sanitize:evidence-bundle": "ts-node tools/evidence/sanitize-live-aws-evidence.ts",
    "infra:synth": "npm run build && GHOST_ARK_ENABLE_SEARCH=false cdk synth -c stage=dev -c enableSearch=false",
    "scan:claims": "node tools/research/check-forbidden-claims.mjs",
    "spine:a": "npm run lint && npm run validate:claims && npm run scan:claims && npm test && npm run docs:check",
    "spine:b": "npm run spine:a && npm run receipt:verify:repro && npm run receipt:verify:sample && npm run receipt:verify:independent && npm run receipt:verify:corpus && npm run receipt:verify:agreement && npm run receipt:verify:replay",
    "spine:c:local": "npm run spine:b && npm run validate:evidence-bundle && npm run infra:synth",
    "spine:d:local": "npx vitest run tests/unit/enforcement-runtime/receipts/test_key_manifest.test.ts",
    "spine:e:local": "npx vitest run tests/unit/research-frontier/guardrailObservation.test.ts",
    "spine:f:local": "npx vitest run tests/unit/research-frontier/ccCorrelation.test.ts",
    "spine:g:local": "npx vitest run tests/unit/enforcement-runtime/receipts/test_checkpoint.test.ts tests/unit/research-frontier/merkle.test.ts tests/unit/research-frontier/witnessCheckpoint.test.ts tests/unit/research-frontier/transparencyArtifacts.test.ts tests/integration/tools/phase567Verify.test.ts",
    "spine:h:local": "npx vitest run tests/unit/research-frontier/humanReview.test.ts",
    "spine:compliance:local": "npx vitest run tests/unit/research-frontier/complianceControlMapping.test.ts",
    "checklist:local": "npm run spine:c:local && npm run spine:d:local && npm run spine:e:local && npm run spine:f:local && npm run spine:g:local && npm run spine:h:local && npm run spine:compliance:local"
  },
  "dependencies": {
    "@aws-sdk/client-athena": "^3.1080.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1081.0",
    "@aws-sdk/client-dynamodb": "^3.1080.0",
    "@aws-sdk/client-glue": "^3.1080.0",
    "@aws-sdk/client-iam": "^3.1080.0",
    "@aws-sdk/client-kms": "^3.1080.0",
    "@aws-sdk/client-lakeformation": "^3.1080.0",
    "@aws-sdk/client-s3": "^3.1080.0",
    "@aws-sdk/client-secrets-manager": "^3.1081.0",
    "@aws-sdk/client-sfn": "^3.1080.0",
    "@aws-sdk/client-sns": "^3.1080.0",
    "@aws-sdk/credential-provider-node": "^3.972.65",
    "@aws-sdk/lib-dynamodb": "^3.1080.0",
    "@aws-sdk/util-format-url": "^3.972.32",
    "@smithy/hash-node": "^4.4.7",
    "@smithy/protocol-http": "^5.5.7",
    "@smithy/signature-v4": "^5.6.3",
    "aws-cdk-lib": "^2.261.0",
    "constructs": "^10.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.152",
    "@types/node": "^24.0.10",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "aws-cdk": "^2.1129.0",
    "esbuild": "^0.25.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
